Pr={1:{"desc":"El estándar profesional para DJ. Pantalla de alta definición, jog wheels mejorados, rendimiento impecable.","specs":["Pantalla táctil LCD de 7 pulgadas","2 canales, 4 zonas de hot cues","Respuesta de frecuencia: 4Hz ~ 20kHz","Separación de canales: 105dB"],"gallery":["/images/pioneer-cdj3000.jpg"]},2:{"desc":"Todo en uno con controles de gran formato, ideal para sets de alto impacto visual y táctil.","specs":["2 canales + pads de rendimiento","Pantalla táctil de 10.1 pulgadas","2 x USB tipo A para rekordbox","Salida XLR balanceada"],"gallery":["/images/pioneer-cdj2000nx2.jpg"]},3:{"desc":"Mezclador profesional de 4 canales para DJ, referencia absoluta en clubs y festivales.","specs":["4 canales de entrada","Faders de canal de 60 mm","Procesador de efectos BeatFX","Salida booth y booth mono/stereo"],"gallery":["/images/pioneer-djm900nx2.jpg"]},4:{"desc":"El tope de gama Pioneer. Mezclador de 6 canales con motor FX avanzado y sampler de 6 slots.","specs":["6 canales (2 MIC/LINE, 2 LINE, 2 PHONO)","Pantalla táctil a color de 3.5 pulgadas","Sampler de 6 slots con controles dedicados","Efectos Sound Color FX y Beat FX"],"gallery":["/images/pioneer-djm-v10.jpg"]},5:{"desc":"Mezclador flagship de 4 canales con interfaz de audio profesional integrada.","specs":["4 canales + 2 puertos USB tipo A/B","Interfaz de audio 24-bit/96kHz","Inserción de efectos por canal","Alimentación phantom en ambos canales MIC"],"gallery":["/images/pioneer-djm-a9.jpg"]},6:{"desc":"Compacto pero poderoso. Ideal para espacios pequeños sin sacrificar calidad profesional.","specs":["2 canales + 2 puertos USB","2 canales PHONO con faders curvos","Procesador de efectos de 13 tipos","Salida booth y grabación directa USB"],"gallery":["/images/pioneer-djm-s11.jpg"]},7:{"desc":"El clásico modernizado. 4 canales con diseño legendario y tecnología actualizada.","specs":["4 canales (2 PHONO / 2 LINE)","Faders de canal de 60 mm","Circuito de fono mejorado","Salida de grabación USB y booth"],"gallery":["/images/pioneer-djm-s9.jpg"]},8:{"desc":"Mezclador de 2 canales de club, robusto y con interfaz de audio de alta calidad.","specs":["2 canales PHONO/LINE","Interfaz de audio USB 24-bit/96kHz","Circuito de fono de alta ganancia","Salida master balanceada XLR/TRS"],"gallery":["/images/pioneer-djm900nx2.jpg"]},9:{"desc":"El mezclador analógico puro. Sin pantalla, cero latencia, control total directo.","specs":["2 canales + send/return externos","Faders VCA de 45mm","EQ de 3 bandas por canal","Salida master y booth balanceadas"],"gallery":["/images/model1.jpg"]},10:{"desc":"Sistema todo-en-uno de 2 canales con pantallas integradas y pads de rendimiento.","specs":["2 decks + mixer integrado","2 pantallas táctiles de 7 pulgadas","Pads RGB de 16 colores","Salidas XLR y RCA balanceadas"],"gallery":["/images/pioneer-xdj-xz.jpg"]},11:{"desc":"Mezclador analógico clásico de 3 bandas, legendario por su sonido cálido y preciso.","specs":["3 bandas de EQ por canal","Faders de 100mm (VCA en estéreo)","Circuito de split de frecuencias","Salida mono/stereo balanceada"],"gallery":["/images/xone96.png"]},12:{"desc":"Versión blanca del clásico, con EQ mejorado y respuesta de frecuencia extendida.","specs":["EQ de 4 bandas (Kill EQ)","Faders VCA de 45mm","Respuesta de frecuencia: 10Hz - 100kHz","Salida balanceada TRS y XLR"],"gallery":["/images/xone-k2.webp"]}};
